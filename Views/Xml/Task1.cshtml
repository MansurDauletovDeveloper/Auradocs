@model List<Dictionary<string, string>>

@{
    ViewData["Title"] = "Task 1 - Read XML with XmlReader";
}

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>
    <p>Displays parsed values and elements from `Data.xml` using `System.Xml.XmlReader`.</p>

    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>Element ID</th>
                <th>Title</th>
                <th>Author</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in Model)
            {
                <tr>
                    <td>@(doc.ContainsKey("Id") ? doc["Id"] : "")</td>
                    <td>@(doc.ContainsKey("Title") ? doc["Title"] : "")</td>
                    <td>@(doc.ContainsKey("Author") ? doc["Author"] : "")</td>
                    <td>@(doc.ContainsKey("Date") ? doc["Date"] : "")</td>
                </tr>
            }
        </tbody>
    </table>
</div>