@model List<DocumentFlow.Controllers.Task6Record>
@{
    ViewData["Title"] = "Task 6 - XML Data Sync";
}

<div class="container mt-4">
    <h2>Task 6: Data Synchronization via XML</h2>
    
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <p>Edit Data populated from <code>DataUpload.xml</code>. Changes will update the XML node directly via <code>XmlDocument</code> and write an audit report to <code>ChangeLog.xml</code>.</p>
    
    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-primary">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Value</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in Model)
            {
                <tr>
                    <form asp-controller="Xml" asp-action="Task6Sync" method="post">
                        <td>
                            @record.Id
                            <input type="hidden" name="id" value="@record.Id" />
                        </td>
                        <td>
                            <input type="text" name="newName" value="@record.Name" class="form-control" required />
                        </td>
                        <td>
                            <input type="text" name="newValue" value="@record.Value" class="form-control" required />
                        </td>
                        <td>
                            <button type="submit" class="btn btn-warning"><i class="bi bi-save"></i> Sync / Save</button>
                        </td>
                    </form>
                </tr>
            }
        </tbody>
    </table>
    
    <div class="mt-4">
        <a asp-controller="Xml" asp-action="Task6History" class="btn btn-secondary">
            <i class="bi bi-clock-history"></i> View Synchronization History (Change Log)
        </a>
    </div>
</div>