@model List<DocumentFlow.Controllers.ChangeLogEntry>
@{
    ViewData["Title"] = "Task 6 - Synchronization History";
}

<div class="container mt-4">
    <h2>Task 6: Synchronization Change Log</h2>
    
    <div class="card bg-light p-3 mb-4 shadow-sm">
        <form method="get" asp-action="Task6History" asp-controller="Xml" class="row gx-3 gy-2 align-items-center">
            <div class="col-sm-4">
                <label class="form-label" for="userFilter">Filter by User</label>
                <input type="text" class="form-control" name="userFilter" id="userFilter" placeholder="e.g. System" value="@ViewBag.UserFilter">
            </div>
            <div class="col-sm-4">
                <label class="form-label" for="dateFilter">Filter by Date</label>
                <input type="date" class="form-control" name="dateFilter" id="dateFilter" value="@ViewBag.DateFilter">
            </div>
            <div class="col-auto mt-4 pt-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-filter"></i> Apply Filters</button>
                <a asp-action="Task6History" asp-controller="Xml" class="btn btn-secondary ms-2"><i class="bi bi-x-circle"></i> Clear Filters</a>
            </div>
        </form>
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th><i class="bi bi-clock"></i> Timestamp</th>
                    <th><i class="bi bi-person"></i> User</th>
                    <th>Record ID</th>
                    <th>New Name</th>
                    <th>New Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@log.User</td>
                        <td><span class="badge bg-secondary">@log.RecordId</span></td>
                        <td>@log.NewName</td>
                        <td>@log.NewValue</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle-fill"></i> No changes logged yet or no records match the criteria.
        </div>
    }

    <div class="mt-3">
        <a asp-action="Task6" asp-controller="Xml" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Back to Sync Page</a>
    </div>
</div>