@model List<Dictionary<string, string>>
@{
    ViewData["Title"] = "Task 4 - ADO.NET to XML";
}

<div class="container mt-4">
    <h2>Task 4: EXPORT DB Data via ADO.NET and READ from XML</h2>
    <p>This data is retrieved from <code>Documents</code> table using ADO.NET, exported to XML, then read back into this view.</p>

    <div class="mb-3">
        <input type="text" id="searchInput" class="form-control w-25 d-inline" placeholder="Search..." onkeyup="filterTable()">
        <button class="btn btn-outline-secondary" onclick="sortTable(1)">Sort by Title</button>
        <button class="btn btn-outline-secondary" onclick="sortTable(3)">Sort by Date</button>
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table table-bordered table-striped" id="xmlTable">
            <thead class="table-dark">
                <tr>
                    <th onclick="sortTable(0)" style="cursor:pointer;">Id <i class="bi bi-sort-down"></i></th>
                    <th onclick="sortTable(1)" style="cursor:pointer;">Title <i class="bi bi-sort-down"></i></th>
                    <th onclick="sortTable(2)" style="cursor:pointer;">Content <i class="bi bi-sort-down"></i></th>
                    <th onclick="sortTable(3)" style="cursor:pointer;">CreatedAt <i class="bi bi-sort-down"></i></th>
                    <th onclick="sortTable(4)" style="cursor:pointer;">AuthorId <i class="bi bi-sort-down"></i></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model)
                {
                    <tr>
                        <td>@(doc.ContainsKey("Id") ? doc["Id"] : "")</td>
                        <td>@(doc.ContainsKey("Title") ? doc["Title"] : "")</td>
                        <td>@(doc.ContainsKey("Content") ? doc["Content"] : "")</td>
                        <td>@(doc.ContainsKey("CreatedAt") ? doc["CreatedAt"] : "")</td>
                        <td>@(doc.ContainsKey("AuthorId") ? doc["AuthorId"] : "")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-warning">No data available or XML was not properly generated.</div>
    }
</div>

@section Scripts {
    <script>
        function filterTable() {
            var input = document.getElementById("searchInput");
            var filter = input.value.toUpperCase();
            var tbody = document.getElementById("xmlTable").getElementsByTagName("tbody")[0];
            var tr = tbody.getElementsByTagName("tr");
            for (var i = 0; i < tr.length; i++) {
                var show = false;
                var tds = tr[i].getElementsByTagName("td");
                for (var j = 0; j < tds.length; j++) {
                    if (tds[j].innerHTML.toUpperCase().indexOf(filter) > -1) {
                        show = true;
                        break;
                    }
                }
                tr[i].style.display = show ? "" : "none";
            }
        }

        var sortOrder = 1;
        function sortTable(n) {
            var table, rows, switching, i, x, y, shouldSwitch, switchcount = 0;
            table = document.getElementById("xmlTable");
            switching = true;
            var dir = sortOrder == 1 ? "asc" : "desc"; 
            
            while (switching) {
                switching = false;
                rows = table.rows;
                for (i = 1; i < (rows.length - 1); i++) {
                    shouldSwitch = false;
                    x = rows[i].getElementsByTagName("TD")[n];
                    y = rows[i + 1].getElementsByTagName("TD")[n];
                    if (dir == "asc") {
                        if (x.innerHTML.toLowerCase() > y.innerHTML.toLowerCase()) {
                            shouldSwitch = true;
                            break;
                        }
                    } else if (dir == "desc") {
                        if (x.innerHTML.toLowerCase() < y.innerHTML.toLowerCase()) {
                            shouldSwitch = true;
                            break;
                        }
                    }
                }
                if (shouldSwitch) {
                    rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
                    switching = true;
                    switchcount++;
                } else {
                    if (switchcount == 0 && dir == "asc") {
                        dir = "desc";
                        sortOrder = -1;
                        switching = true;
                    }
                }
            }
            sortOrder = dir == "asc" ? -1 : 1;
        }
    </script>
}