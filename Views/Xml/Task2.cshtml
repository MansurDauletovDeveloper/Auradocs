@model List<DocumentFlow.Controllers.UserXmlModel>

@{
    ViewData["Title"] = "Task 2 - LINQ to XML";
}

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>
    <p>Filters users from `Users.xml` using `XDocument` and LINQ to XML.</p>

    <form method="get" class="mb-3 d-flex align-items-center">
        <label for="roleFilter" class="me-2">Filter by Role:</label>
        <select name="roleFilter" id="roleFilter" class="form-select w-auto me-2">
            <option value="">All Users</option>
            <option value="admin" selected="@(ViewBag.CurrentFilter == "admin")">Admin</option>
            <option value="user" selected="@(ViewBag.CurrentFilter == "user")">User</option>
        </select>
        <button type="submit" class="btn btn-primary">Filter</button>
    </form>

    <table class="table table-bordered table-hover">
        <thead class="table-primary">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                </tr>
            }
        </tbody>
    </table>
</div>