@model DocumentFlow.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Вход в систему";
    Layout = "_Layout";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="card-header">
            <i class="bi bi-shield-lock auth-icon d-block" style="font-size: 2.25rem; margin-bottom: 0.625rem; opacity: 0.8;"></i>
            <h4>Вход в систему</h4>
            <p class="mb-0 small" style="color: var(--slate-400);">Добро пожаловать в DocFlow</p>
        </div>
        <div class="card-body">
            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="alert alert-secondary" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="user@example.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-secondary small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Пароль</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-key"></i></span>
                        <input asp-for="Password" class="form-control" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-secondary small"></span>
                </div>

                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Запомнить меня</label>
                    </div>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Войти
                    </button>
                </div>
            </form>
        </div>
        <div class="card-footer">
            <p class="mb-0 small text-muted">
                <i class="bi bi-shield-check me-1"></i>
                Для получения доступа обратитесь к администратору
            </p>
        </div>
    </div>

    <div class="auth-hint" style="max-width: 420px; width: 100%;" data-collapsible>
        <h6><i class="bi bi-info-circle text-primary" style="color: var(--teal-500) !important;"></i>Тестовые аккаунты</h6>
        <ul>
            <li><strong>Администратор:</strong> admin@documentflow.local / Admin123!</li>
            <li><strong>Руководитель:</strong> manager@documentflow.local / Manager123!</li>
            <li><strong>Сотрудник:</strong> employee@documentflow.local / Employee123!</li>
        </ul>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

