@{
    ViewData["Title"] = "DocFlow";
}

<div style="position: relative; overflow: hidden; min-height: calc(100vh - 140px);">
    <!-- Background shapes -->
    <div class="landing-bg-shape landing-bg-shape-1"></div>
    <div class="landing-bg-shape landing-bg-shape-2"></div>

    <div class="container py-5">
        <div class="landing-hero">
            <div class="landing-hero-content">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="sidebar-brand-icon" style="width: 42px; height: 42px; font-size: 1.25rem;">
                        <i class="bi bi-stack"></i>
                    </div>
                    <span style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 1.15rem; color: var(--slate-500);">DocFlow</span>
                </div>

                <h1>
                    Умный <span class="text-gradient">документооборот</span>
                    для вашей команды
                </h1>

                <p class="lead">
                    Создавайте, согласовывайте и управляйте документами в единой системе.
                    Прозрачные процессы, быстрые решения, полный контроль.
                </p>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg">
                        <i class="bi bi-grid-1x2 me-2"></i>Перейти в систему
                    </a>
                }
                else
                {
                    <div class="d-flex flex-column flex-sm-row gap-3">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-4">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Войти в систему
                        </a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary btn-lg px-4">
                            Регистрация
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="landing-features">
            <div class="feature-card">
                <div class="feature-icon" style="background: var(--teal-100); color: var(--teal-600);">
                    <i class="bi bi-file-earmark-check"></i>
                </div>
                <h5 style="font-size: 1rem; margin-bottom: 0.375rem;">Создание документов</h5>
                <p style="font-size: 0.85rem; color: var(--slate-500); margin: 0; line-height: 1.5;">
                    Шаблоны, версионирование и загрузка файлов — всё в одном месте
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon" style="background: var(--amber-100); color: var(--amber-600);">
                    <i class="bi bi-clipboard2-check"></i>
                </div>
                <h5 style="font-size: 1rem; margin-bottom: 0.375rem;">Согласование</h5>
                <p style="font-size: 0.85rem; color: var(--slate-500); margin: 0; line-height: 1.5;">
                    Гибкие маршруты, комментарии и история каждого решения
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon" style="background: var(--rose-100); color: var(--rose-600);">
                    <i class="bi bi-bell"></i>
                </div>
                <h5 style="font-size: 1rem; margin-bottom: 0.375rem;">Уведомления</h5>
                <p style="font-size: 0.85rem; color: var(--slate-500); margin: 0; line-height: 1.5;">
                    Мгновенные оповещения о новых событиях и ожидающих действиях
                </p>
            </div>
        </div>

        <div class="text-center mt-5 pt-4">
            <p style="font-size: 0.8rem; color: var(--slate-400);">
                <i class="bi bi-lock me-1"></i>Безопасная система — доступ только авторизованным пользователям
            </p>
        </div>
    </div>
</div>
