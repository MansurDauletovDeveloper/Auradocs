<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#0d9488" />
    <meta name="description" content="DocFlow — Система электронного документооборота" />
    <title>@ViewData["Title"] - DocFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Sidebar Navigation -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Меню">
            <i class="bi bi-list"></i>
        </button>

        <aside class="sidebar" id="sidebar">
            <!-- Brand -->
            <div class="sidebar-brand">
                <div class="sidebar-brand-icon">
                    <i class="bi bi-stack"></i>
                </div>
                <div class="sidebar-brand-text">
                    DocFlow
                    <small>Документооборот</small>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="sidebar-nav">
                <div class="sidebar-section">
                    <p class="sidebar-section-title">Навигация</p>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-grid-1x2"></i>
                        <span>Главная</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Documents" && ViewContext.RouteData.Values["action"]?.ToString() != "Create" ? "active" : "")"
                       asp-controller="Documents" asp-action="Index">
                        <i class="bi bi-folder2-open"></i>
                        <span>Документы</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" && ViewContext.RouteData.Values["controller"]?.ToString() == "Documents" ? "active" : "")"
                       asp-controller="Documents" asp-action="Create">
                        <i class="bi bi-plus-circle"></i>
                        <span>Создать документ</span>
                    </a>
                </div>

                @if (User.IsInRole("Manager") || User.IsInRole("Administrator"))
                {
                    <div class="sidebar-section">
                        <p class="sidebar-section-title">Согласование</p>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Approval" ? "active" : "")"
                           asp-controller="Approval" asp-action="Index">
                            <i class="bi bi-clipboard2-check"></i>
                            <span>Согласования</span>
                        </a>
                    </div>
                }

                @if (User.IsInRole("Administrator"))
                {
                    <div class="sidebar-section">
                        <p class="sidebar-section-title">Управление</p>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")"
                           asp-controller="Admin" asp-action="Users">
                            <i class="bi bi-people"></i>
                            <span>Пользователи</span>
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Templates" ? "active" : "")"
                           asp-controller="Templates" asp-action="Index">
                            <i class="bi bi-file-earmark-ruled"></i>
                            <span>Шаблоны</span>
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "AuditLogs" ? "active" : "")"
                           asp-controller="Admin" asp-action="AuditLogs">
                            <i class="bi bi-journal-text"></i>
                            <span>Журнал аудита</span>
                        </a>
                    </div>
                }

                @if (User.IsInRole("Administrator") || User.IsInRole("ITIntegrator"))
                {
                    <div class="sidebar-section">
                        <p class="sidebar-section-title">IT Администрирование</p>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ITAdmin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                           asp-controller="ITAdmin" asp-action="Index">
                            <i class="bi bi-speedometer"></i>
                            <span>Панель управления</span>
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ITAdmin" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")"
                           asp-controller="ITAdmin" asp-action="Users">
                            <i class="bi bi-shield-lock"></i>
                            <span>Права</span>
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ITAdmin" && ViewContext.RouteData.Values["action"]?.ToString() == "Sessions" ? "active" : "")"
                           asp-controller="ITAdmin" asp-action="Sessions">
                            <i class="bi bi-activity"></i>
                            <span>Сессии</span>
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ITAdmin" && ViewContext.RouteData.Values["action"]?.ToString() == "Roles" ? "active" : "")"
                           asp-controller="ITAdmin" asp-action="Roles">
                            <i class="bi bi-tags"></i>
                            <span>Роли</span>
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ITAdmin" && ViewContext.RouteData.Values["action"]?.ToString() == "TestAccounts" ? "active" : "")"
                           asp-controller="ITAdmin" asp-action="TestAccounts">
                            <i class="bi bi-key"></i>
                            <span>Тест. аккаунты</span>
                        </a>
                    </div>
                }

                <div class="sidebar-section">
                    <p class="sidebar-section-title">XML Задачи</p>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Xml" && ViewContext.RouteData.Values["action"]?.ToString() == "Task1" ? "active" : "")"
                       asp-controller="Xml" asp-action="Task1">
                        <i class="bi bi-filetype-xml"></i>
                        <span>Task 1 (XmlReader)</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Xml" && ViewContext.RouteData.Values["action"]?.ToString() == "Task2" ? "active" : "")"
                       asp-controller="Xml" asp-action="Task2">
                        <i class="bi bi-search"></i>
                        <span>Task 2 (LINQ)</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Xml" && ViewContext.RouteData.Values["action"]?.ToString() == "Task3" ? "active" : "")"
                       asp-controller="Xml" asp-action="Task3">
                        <i class="bi bi-code-slash"></i>
                        <span>Task 3 (XSLT)</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Xml" && ViewContext.RouteData.Values["action"]?.ToString() == "Task4" ? "active" : "")"
                       asp-controller="Xml" asp-action="Task4">
                        <i class="bi bi-file-earmark-spreadsheet"></i>
                        <span>Task 4 (ADO.NET)</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Xml" && ViewContext.RouteData.Values["action"]?.ToString() == "Task5" ? "active" : "")"
                       asp-controller="Xml" asp-action="Task5">
                        <i class="bi bi-file-check"></i>
                        <span>Task 5 (XSD)</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Xml" && (ViewContext.RouteData.Values["action"]?.ToString() == "Task6" || ViewContext.RouteData.Values["action"]?.ToString() == "Task6History") ? "active" : "")"
                       asp-controller="Xml" asp-action="Task6">
                        <i class="bi bi-arrow-repeat"></i>
                        <span>Task 6 (Sync)</span>
                    </a>
                </div>

                <div class="sidebar-section">
                    <p class="sidebar-section-title">Уведомления</p>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notifications" ? "active" : "")"
                       asp-controller="Notifications" asp-action="Index">
                        <i class="bi bi-bell"></i>
                        <span>Уведомления</span>
                        <span id="notificationBadge" class="badge rounded-pill bg-secondary d-none">0</span>
                    </a>
                </div>
            </nav>

            <!-- User Footer -->
            <div class="sidebar-footer">
                <div class="dropdown">
                    <a class="sidebar-user" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="sidebar-user-avatar">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div class="sidebar-user-info">
                            <div class="sidebar-user-name">@User.Identity?.Name</div>
                        </div>
                        <i class="bi bi-chevron-expand" style="font-size: 0.7rem; color: var(--slate-400);"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end mb-1" style="min-width: 200px;">
                        <li class="dropdown-header px-3 py-2">
                            <small class="text-muted">Аккаунт</small>
                        </li>
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person-circle"></i>Мой профиль</a></li>
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-shield-lock"></i>Сменить пароль</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item text-secondary"><i class="bi bi-box-arrow-right"></i>Выйти</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="main-content">
            <div class="main-inner">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-primary alert-dismissible fade show animate-slide-up mb-4" role="alert">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@TempData["SuccessMessage"]</span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-secondary alert-dismissible fade show animate-slide-up mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>@TempData["ErrorMessage"]</span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
                    </div>
                }
                @RenderBody()
            </div>

            <footer class="app-footer">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                    <small>&copy; @DateTime.Now.Year DocFlow — Документооборот</small>
                    <small class="text-muted">v2.0</small>
                </div>
            </footer>
        </div>
    }
    else
    {
        <!-- Public layout — no sidebar -->
        <header>
            <nav class="navbar navbar-expand-lg navbar-dark" style="background: var(--slate-800) !important; display: flex !important; padding: 0.75rem 1.5rem;">
                <div class="container-fluid">
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index" style="color: #fff; text-decoration: none;">
                        <div class="sidebar-brand-icon" style="width: 34px; height: 34px; font-size: 1rem;">
                            <i class="bi bi-stack"></i>
                        </div>
                        <span style="font-family: 'Segoe UI', sans-serif; font-weight: 700; font-size: 1.15rem;">DocFlow</span>
                    </a>
                    <div class="d-flex align-items-center gap-2">
                        <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Login"
                           style="border-color: var(--blue-400); color: var(--blue-300);">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Вход
                        </a>
                    </div>
                </div>
            </nav>
        </header>

        <main style="flex: 1;">
            <div class="animate-fade-in">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="container-fluid py-3">
                        <div class="alert alert-primary alert-dismissible fade show animate-slide-up" role="alert">
                            <i class="bi bi-check-circle-fill"></i>
                            <span>@TempData["SuccessMessage"]</span>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
                        </div>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="container-fluid py-3">
                        <div class="alert alert-secondary alert-dismissible fade show animate-slide-up" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>@TempData["ErrorMessage"]</span>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
                        </div>
                    </div>
                }
                @RenderBody()
            </div>
        </main>

        <footer class="app-footer" style="display: block !important;">
            <div class="container">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                    <small>&copy; @DateTime.Now.Year DocFlow — Документооборот</small>
                    <small class="text-muted">v2.0</small>
                </div>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            (function() {
                function updateBadge() {
                    fetch('/Notifications/GetUnreadCount')
                        .then(r => r.json())
                        .then(d => {
                            const b = document.getElementById('notificationBadge');
                            if (d.count > 0) {
                                b.textContent = d.count > 9 ? '9+' : d.count;
                                b.classList.remove('d-none');
                            } else {
                                b.classList.add('d-none');
                            }
                        }).catch(() => {});
                }
                updateBadge();
                setInterval(updateBadge, 60000);
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>




